{
  "caption": "MOTW",
  "description": "The MOTW object describes <a target='_blank' href='https://en.wikipedia.org/wiki/Mark_of_the_Web'>Mark of the Web</a> metadata attached to a file.",
  "extends": "object",
  "name": "motw",
  "attributes": {
    "host_ip_address": {
      "requirement": "optional"
    },
    "host_url": {
      "requirement": "recommended"
    },
    "motw_zone": {
      "requirement": "optional"
    },
    "motw_zone_id": {
      "requirement": "required"
    },
    "referrer_url": {
      "requirement": "optional"
    }
  }
}