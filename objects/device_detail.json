{
  "caption": "Device Detail",
  "description": "Extended device context: network interfaces, management and posture flags, and risk scoring. Use together with the base <code>device</code> object for inventory, EDR posture, and rich host telemetry. The parent <code>device</code> (via <code>endpoint</code>) already carries <code>os</code>, <code>hw_info</code>, and <code>agent_list</code>; this object adds interfaces and posture or risk fields that are often sparse or high-cardinality.",
  "extends": "device",
  "name": "device_detail",
  "attributes": {
    "is_backed_up": {
      "requirement": "optional"
    },
    "is_compliant": {
      "requirement": "optional"
    },
    "is_managed": {
      "requirement": "optional"
    },
    "is_mobile_account_active": {
      "requirement": "optional"
    },
    "is_personal": {
      "requirement": "optional"
    },
    "is_shared": {
      "requirement": "optional"
    },
    "is_supervised": {
      "requirement": "optional"
    },
    "is_trusted": {
      "requirement": "optional"
    },
    "network_interfaces": {
      "requirement": "optional"
    },
    "risk_level": {
      "requirement": "optional"
    },
    "risk_level_id": {
      "requirement": "optional"
    },
    "risk_score": {
      "requirement": "optional"
    }
  },
  "references": [
    {
      "description": "D3FEND™ Ontology d3f:Host.",
      "url": "https://d3fend.mitre.org/dao/artifact/d3f:Host/"
    }
  ]
}
