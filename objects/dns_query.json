{
  "caption": "DNS Query",
  "description": "The DNS Query object represents a specific request made to the Domain Name System (DNS) to retrieve information about a domain or perform a DNS operation.",
  "extends": "_dns",
  "name": "dns_query",
  "attributes": {
    "hostname": {
      "description": "The hostname or domain being queried. For example: <code>www.example.com</code>",
      "requirement": "required"
    },
    "opcode": {
      "requirement": "optional",
      "@deprecated": {
        "message": "Use <code>opcode</code> on <code>DNS Activity</code> instead.",
        "since": "1.9.0"
      }
    },
    "opcode_id": {
      "requirement": "recommended",
      "@deprecated": {
        "message": "Use <code>opcode_id</code> on <code>DNS Activity</code> instead.",
        "since": "1.9.0"
      }
    }
  },
  "references": [
    {
      "description": "D3FEND™ Ontology d3f:DNSLookup.",
      "url": "https://d3fend.mitre.org/dao/artifact/d3f:DNSLookup/"
    }
  ]
}
